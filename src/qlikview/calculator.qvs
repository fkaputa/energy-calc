Fluvius:
LOAD 
	*
	, 'key:' & TimeStamp(datequarterhour) as datequarterhour_key
	, 0 as inj_power_kw
RESIDENT T;
DROP Table T;


///$tab Combine

LEFT JOIN (Fluvius)
LOAD
	datequarterhour_key
	, pv_power_kw as temp_pv_power_kw
RESIDENT PV;

DROP TABLE PV;
///$tab Generic

SET ThousandSep=',';
SET DecimalSep='.';


TempPower:
LOAD 
	*
	, 1 as matchFlag
	, og_power_kw as [Afname (KW)]
	, 0 as [Injectie (KW)]
	, og_power_kw as [Active Power (KW)]
	, 0 as [Reactive Power (KVR)]
	
	, og_power_kw as c2_power_kw
	, og_power_kw as c1_power_kw
	
	// power_kw used for BESS simulation
	, (og_power_kw - pv_power_kw) as power_kw
	
	// power scenario 	
	, cons_power_kw as power_scen1_kw
	, - inj_power_kw as power_scen2_kw
	, og_power_kw as power_scen3_kw
	, (og_power_kw - pv_power_kw) as power_scen4_kw
	, (- pv_power_kw) as power_scen5_kw
	
	// high power
	, og_power_kw - RangeMin(og_power_kw,$(vHighPower)) as high_power_kw
	, RangeMax(0, RangeMin(og_power_kw,$(vBasePower))) as base_power_kw
	, cons_power_kw - RangeMin(cons_power_kw,$(vHighPower)) as high_power_scen1_kw
	, RangeMax(0, RangeMin(cons_power_kw,$(vBasePower))) as base_power_scen1_kw
	, - inj_power_kw - RangeMin(- inj_power_kw,$(vHighPower)) as high_power_scen2_kw
	, RangeMax(0, RangeMin(- inj_power_kw,$(vBasePower))) as base_power_scen2_kw
	, og_power_kw - RangeMin(og_power_kw,$(vHighPower)) as high_power_scen3_kw
	, RangeMax(0, RangeMin(og_power_kw,$(vBasePower))) as base_power_scen3_kw
	, (og_power_kw - pv_power_kw) - RangeMin((og_power_kw - pv_power_kw),$(vHighPower)) as high_power_scen4_kw
	, RangeMax(0, RangeMin((og_power_kw - pv_power_kw),$(vBasePower))) as base_power_scen4_kw
	, (- pv_power_kw) - RangeMin((- pv_power_kw),$(vHighPower)) as high_power_scen5_kw
	, RangeMax(0, RangeMin((- pv_power_kw),$(vBasePower))) as base_power_scen5_kw
;
LOAD 
	*
	, RangeSum(cons_power_kw, - inj_power_kw) as og_power_kw
	, RangeSum(0,temp_pv_power_kw) as pv_power_kw
RESIDENT Fluvius;
DROP TABLE Fluvius;
RENAME TABLE TempPower To Power;

///$tab Dates

Date:
LOAD DISTINCT 
	datequarterhour
	, Year(datequarterhour) as year
	, TimeStamp(Floor(datequarterhour) + hour(datequarterhour) / 24) as datehour
	, hour(datequarterhour) as hour
	, Date(Floor(datequarterhour)) as date
	, Date(MonthStart(Floor(datequarterhour)),'MMM-YY') as monthyear
	, Month(datequarterhour) as month
	, WeekDay(datequarterhour) as weekday
	, Minute(datequarterhour) as minute
	, Time(frac(datequarterhour),'hh:mm') as hourminute
	, Date(WeekStart(Floor(datequarterhour))) as weekstart
RESIDENT [Power];

LEFT JOIN (Power)
LOAD 
	datequarterhour
	, monthyear as my
RESIDENT Date;

///$tab PV_BESS

// Calculate BESS reacting on PV only: charging when net injecting
SET vEfficiency = .88;

TempPower:
LOAD 

	// CASE: certain months CHRG WITH PV OR AT NIGHT DCHRG INTO HIGH PEAK POWER BAND ELSE in all bands
	If(WildMatch(Num(Month(datequarterhour)),0)>0, // 1,12,11
		If(power_kw < 0 
			, RangeMin(RangeMin(RangeMax($(vBatkWh) - RangeMax(0,Peek('bess_pv_capacity_kwh')), 0) * 4, $(vBatkW)), - power_kw) 
			, If(high_power_kw = 0 and (hour(datequarterhour) < 23 OR hour(datequarterhour) > 16)
				// Charge from net when no highpower usage
				, RangeMin(RangeMin(RangeMax($(vBatkWh) - RangeMax(0,Peek('bess_pv_capacity_kwh')), 0) * 4, $(vBatkW)), $(vHighPower) - power_kw)
				// DCHRG INTO HIGH PEAK POWER BAND
				, if(high_power_kw > 0
					, - RangeMin(RangeMin(RangeMin(RangeMax(0,Peek('bess_pv_capacity_kwh')),$(vBatkWh)) * 4, $(vBatkW)), high_power_kw),0)))
		, If(power_kw < 0
			// CHRG from PV
			, RangeMin(RangeMin(RangeMax($(vBatkWh) - RangeMax(0,Peek('bess_pv_capacity_kwh')), 0) * 4, $(vBatkW)), - power_kw)
			// DCHRG INTO ALL POWER BANDS
			, - RangeMin(RangeMin(RangeMin(RangeMax(0,Peek('bess_pv_capacity_kwh')),$(vBatkWh)) * 4, $(vBatkW)), power_kw))
		) as bess_pv_power_kw,
	// For analysis purposes
	// CASE: in DEC-JAN CHRG WITH PV OR AT NIGHT DCHRG INTO HIGH PEAK POWER BAND ELSE in all bands
	If(Match(Num(Month(datequarterhour)),1,12)>0,
		If(power_kw < 0 
			, 'Charge from PV' 
			, If(high_power_kw = 0 and (hour(datequarterhour) < 23 OR hour(datequarterhour) > 0)
				// 
				, 'Charge from net when no basepower usage'
				// DCHRG INTO HIGH PEAK POWER BAND
				, if(high_power_kw > 0
					, 'Discharge into high power band'
					,'Do nothing')))
		, If(power_kw < 0
			, 'Charge from PV'
			// DCHRG INTO ALL POWER BANDS
			, 'Discharge from BESS')
		) as bess_pv_power_comment

		
	
	, RangeMax(RangeMin(RangeSum(RangeMax(0,Peek('bess_pv_capacity_kwh')), Peek('bess_pv_power_kw')/4),$(vBatkWh)),0) as bess_pv_capacity_kwh
	, *
	// High Power Flags & Sequences
	, If((Peek('high_power_kw') = 0 and high_power_kw > 0) OR (Peek('high_power_kw') > 0 and high_power_kw = 0), RangeSum(Peek('high_power_seq'),+1), Peek('high_power_seq')) as high_power_seq
	, If(high_power_kw > 0, 1, 0) as high_power_flag
	, If((Peek('high_power_scen1_kw') = 0 and high_power_scen1_kw > 0) OR (Peek('high_power_scen1_kw') > 0 and high_power_scen1_kw = 0), RangeSum(Peek('high_power_scen1_seq'),+1), Peek('high_power_scen1_seq')) as high_power_scen1_seq
	, If(high_power_scen1_kw > 0, 1, 0) as high_power_scen1_flag
	, If((Peek('high_power_scen2_kw') = 0 and high_power_scen2_kw > 0) OR (Peek('high_power_scen2_kw') > 0 and high_power_scen2_kw = 0), RangeSum(Peek('high_power_scen2_seq'),+1), Peek('high_power_scen2_seq')) as high_power_scen2_seq
	, If(high_power_scen2_kw > 0, 1, 0) as high_power_scen2_flag
	, If((Peek('high_power_scen3_kw') = 0 and high_power_scen3_kw > 0) OR (Peek('high_power_scen3_kw') > 0 and high_power_scen3_kw = 0), RangeSum(Peek('high_power_scen3_seq'),+1), Peek('high_power_scen3_seq')) as high_power_scen3_seq
	, If(high_power_scen3_kw > 0, 1, 0) as high_power_scen3_flag
	, If((Peek('high_power_scen4_kw') = 0 and high_power_scen4_kw > 0) OR (Peek('high_power_scen4_kw') > 0 and high_power_scen4_kw = 0), RangeSum(Peek('high_power_scen2_seq'),+1), Peek('high_power_scen4_seq')) as high_power_scen4_seq
	, If(high_power_scen4_kw > 0, 1, 0) as high_power_scen4_flag
	, If((Peek('high_power_scen5_kw') = 0 and high_power_scen5_kw > 0) OR (Peek('high_power_scen5_kw') > 0 and high_power_scen5_kw = 0), RangeSum(Peek('high_power_scen5_seq'),+1), Peek('high_power_scen5_seq')) as high_power_scen5_seq
	, If(high_power_scen5_kw > 0, 1, 0) as high_power_scen5_flag
RESIDENT Power
ORDER BY EAN, datequarterhour asc; 
DROP TABLE Power; 


Power: 
LOAD
	*
	, If((Peek('high_power_scen6_kw') = 0 and high_power_scen6_kw > 0) OR (Peek('high_power_scen6_kw') > 0 and high_power_scen6_kw = 0), RangeSum(Peek('high_power_scen6_seq'),+1), Peek('high_power_scen6_seq')) as high_power_scen6_seq
	, If(high_power_scen6_kw > 0, 1, 0) as high_power_scen6_flag
;
LOAD
	*
	, RangeSum(power_kw, bess_pv_power_kw) as c3_power_kw
	, RangeSum(power_kw, bess_pv_power_kw) as power_scen6_kw
	, RangeSum(power_kw, bess_pv_power_kw) - RangeMin(RangeSum(power_kw, bess_pv_power_kw),$(vHighPower)) as high_power_scen6_kw
	, RangeMax(0, RangeMin(RangeSum(power_kw, bess_pv_power_kw),$(vBasePower))) as base_power_scen6_kw
	, bess_pv_capacity_kwh as bess_pv_scen6_capacity_kwh
Resident TempPower
ORDER BY EAN, datequarterhour asc; 
DROP TABLE TempPower;
///$tab Calculations
//---------------- CALCULATIONS ---------------
QhData:
LOAD 
	*
     // use fixed peak
    , RangeMax(0,$(vAansluiting) - RangeMax(0,[Apparent Power (kVA)])) as [Bandbreedte Power (kVA)]
    , RangeMax(0,$(vAansluiting)/4 - RangeMax(0,[Apparent Energy (kVAh)])) as [Bandbreedte Energy (kVAh)]
    , RangeMax(0,$(vAansluiting) - RangeMax(0,[Afname (kVA)])) as [Bandbreedte (kVA)]
    , RangeMax(0,$(vAansluiting)/4 - RangeMax(0,[Afname (kVAh)])) as [Bandbreedte (kVAh)]
    , RangeMax(0,$(vAansluiting) - RangeMax(0,[Afname (kW)])) as [Bandbreedte (kW)]
    , RangeMax(0,$(vAansluiting)/4 - RangeMax(0,[Afname (kWh)])) as [Bandbreedte (kWh)]
    , RangeMin(0,- $(vAansluiting_Injectie) - RangeMin(0,[Injectie (kW)])) as [Bandbreedte Injectie (kW)]
    , RangeMin(0,- $(vAansluiting_Injectie)/4 - RangeMin(0,[Injectie (kWh)])) as [Bandbreedte Injectie (kWh)]
; 
LOAD 
	*
	// REQUIRED FIELDS
//	, RangeSum([Active Energy (KW)],0) AS [Afname (kW)]
//	, RangeSum([Active Energy (KW)],0)/4 AS [Afname (kWh)]

	, Sqrt(RangeSum(Pow([Afname (KW)],2),Pow([Reactive Power (KVR)],2))) AS [Afname (kVA)] // https://control.com/technical-articles/active-power-reactive-power-apparent-power-and-the-role-of-power-factor/
	, Sqrt(RangeSum(Pow([Afname (KW)],2),Pow([Reactive Power (KVR)],2)))/4 AS [Afname (kVAh)] // Appparent Power : S^2 = P^2 + Q^2 (Where S = Apparent Power measured in kVA, Q = Reactive Power in kVAR and P = Active Power in kW)

	, If([Active Power (KW)] < 0, -1, 1) * Sqrt(RangeSum(Pow([Active Power (KW)],2),Pow([Reactive Power (KVR)],2))) AS [Apparent Power (kVA)] // https://control.com/technical-articles/active-power-reactive-power-apparent-power-and-the-role-of-power-factor/
	, If([Active Power (KW)] < 0, -1, 1) * Sqrt(RangeSum(Pow([Active Power (KW)],2),Pow([Reactive Power (KVR)],2)))/4 AS [Apparent Energy (kVAh)] // Appparent Power : S^2 = P^2 + Q^2 (Where S = Apparent Power measured in kVA, Q = Reactive Power in kVAR and P = Active Power in kW)
	, [Active Power (KW)] AS [Active Power (kW)]
	, [Active Power (KW)] / 4 AS [Active Energy (kWh)]
	// Afname & Injectie apart
	, [Afname (KW)] AS [Afname (kW)]
	, [Afname (KW)]/4 AS [Afname (kWh)]
	, [Injectie (KW)] / 4 AS [Injectie (kWh)]
	, [Injectie (KW)] as [Injectie (kW)]
;
LOAD 
	*
	, EAN & '|' & my as my_key 
RESIDENT Power;
DROP TABLE Power;
///$tab Power Regime
RENAME TABLE QhData TO Power;
SET vPower_Regime = power_scen4_kw;

TempPower:
LOAD
	*
	, If($(vPower_Regime) > $(vHighPower), 1,0) as regime_high_flag
	, If($(vPower_Regime) > $(vHighPower) AND Peek('$(vPower_Regime)') < $(vHighPower)
		, RangeSum(Peek('regime_high_id'),1)
		, If($(vPower_Regime) < $(vHighPower) AND Peek('$(vPower_Regime)') > $(vHighPower)
			, RangeSum(Peek('regime_high_id'),1)
			, Peek('regime_high_id'))) as regime_high_id
RESIDENT
	Power
ORDER BY EAN, datequarterhour;

DROP TABLE Power;
RENAME TABLE TempPower TO Power;

Regime:
LOAD
	regime_high_id
	, Sum($(vPower_Regime)-$(vHighPower))/4 as regime_high_kwh
RESIDENT Power
GROUP BY [regime_high_id];
	

//===== CALCULATION OF BESS WITH HIGH POWER LIMITATION =====
// we will try to remove the high power band; limiting monthly peak and reducing distr. costs
// how: we know (or need to forecast in later phase) the high power band required kwh
// In the regime preceding this high power regime we will pick the newest date which equals such kwh availabl

Left Join (Power)
LOAD 
	regime_high_id
	, regime_high_kwh as regime_high_qh_kwh
RESIDENT Regime;

Left Join (Power)
LOAD 
	regime_high_id  - 1 as regime_high_id
	, regime_high_kwh as regime_high_nextqh_kwh
RESIDENT Regime;
///$tab BESS Opt
// Calculate BESS reacting on PV only: charging when net injecting
SET vEfficiency = .88;

TempPower:
LOAD 
	*
	// CASE: in DEC-JAN CHRG WITH PV OR AT NIGHT DCHRG INTO HIGH PEAK POWER BAND ELSE in all bands
	, If(WildMatch(Num(Month(datequarterhour)),0)>0, // 1,12,11
		If(power_kw < 0 
			, RangeMin(RangeMin(RangeMax($(vBatkWh) - RangeMax(0,Peek('bess_pv_pk_capacity_kwh')), 0) * 4, $(vBatkW)), - power_kw) 
			, If(high_power_kw = 0 and (hour(datequarterhour) < 23 OR hour(datequarterhour) > 16)
				// Charge from net when no highpower usage
				, RangeMin(RangeMin(RangeMax($(vBatkWh) - RangeMax(0,Peek('bess_pv_pk_capacity_kwh')), 0) * 4, $(vBatkW)), $(vHighPower) - power_kw)
				// DCHRG INTO HIGH PEAK POWER BAND
				, if(high_power_kw > 0
					, - RangeMin(RangeMin(RangeMin(RangeMax(0,Peek('bess_pv_pk_capacity_kwh')),$(vBatkWh)) * 4, $(vBatkW)), high_power_kw),0)))
		, If(power_kw < 0
			// CHRG from PV
			, RangeMin(RangeMin(RangeMax($(vBatkWh) - RangeMax(0,Peek('bess_pv_pk_capacity_kwh')), 0) * 4, $(vBatkW)), - power_kw)
			, If(regime_high_flag = 0 AND regime_high_nextqh_kwh > 0
				, If(regime_high_nextqh_kwh > Peek('bess_pv_pk_capacity_kwh')
					// CHARGE UPTO MIN. NEXT QH
					, RangeMin(RangeMin(RangeMax($(vBatkWh) - RangeMax(0,Peek('bess_pv_pk_capacity_kwh')), 0) * 4, $(vBatkW)), $(vHighPower) - power_kw)					
					// DCHRG PARTIAL INTO ALL POWER BANDS
					, - RangeMin(RangeMin(RangeMin(RangeMax(0,Peek('bess_pv_pk_capacity_kwh') - regime_high_nextqh_kwh),$(vBatkWh)) * 4, $(vBatkW)), power_kw))
				, If(regime_high_flag = 1
					// DCHRG FULL INTO HIGH POWER BAND
					, - RangeMin(RangeMin(RangeMin(RangeMax(0,Peek('bess_pv_pk_capacity_kwh')),$(vBatkWh)) * 4, $(vBatkW)), power_kw - $(vHighPower))
					// DCHRG FULL INTO ALL POWER BANDS
					, - RangeMin(RangeMin(RangeMin(RangeMax(0,Peek('bess_pv_pk_capacity_kwh')),$(vBatkWh)) * 4, $(vBatkW)), power_kw))))
		) as bess_pv_pk_power_kw
	
	, RangeMax(RangeMin(RangeSum(RangeMax(0,Peek('bess_pv_pk_capacity_kwh')), Peek('bess_pv_pk_power_kw')/4),$(vBatkWh)),0) as bess_pv_pk_capacity_kwh	
RESIDENT Power
ORDER BY EAN, datequarterhour asc; 
DROP TABLE Power; 

QhData:
LOAD 
	*
	// High Power Flags & Sequences
	, If((Peek('high_power_scen7_kw') = 0 and high_power_scen7_kw > 0) OR (Peek('high_power_scen7_kw') > 0 and high_power_scen7_kw = 0), RangeSum(Peek('high_power_scen7_seq'),+1), Peek('high_power_scen7_seq')) as high_power_scen7_seq
	, If(high_power_scen7_kw > 0, 1, 0) as high_power_scen7_flag	
;	
LOAD 
	*
	// extra FIELDS
	, (bess_pv_pk_power_kw + $(vPower_Regime)) - RangeMin((bess_pv_pk_power_kw + $(vPower_Regime)),$(vHighPower)) as high_power_scen7_kw
	, RangeMax(0, RangeMin((bess_pv_pk_power_kw + $(vPower_Regime)),$(vBasePower))) as base_power_scen7_kw
	, RangeSum(bess_pv_pk_power_kw, $(vPower_Regime)) as power_scen7_kw
	, bess_pv_pk_capacity_kwh as bess_pv_scen7_capacity_kwh
RESIDENT TempPower
ORDER BY EAN, datequarterhour asc;
DROP TABLE TempPower; 
///$tab Distr Cost
//Variabelen:
//1.	Y = Piekvermogen (MW) 
//2.	X = Verbruik (MWh)
//3.	A = Toegansvermogen (MW)
//4.	I = Injectie (MWh)
//Coëfficiënten: 
//1.	Verschilt per  regio en aansluiting:
//1.1) E = Fractie transmissie (Elia) (%)
//1.2) V = prijs per MW aansluitvermogen  A (€:/MW); dus  C(A) = A*V(€)
//1.3) P = prijs per  MW piekvermogen Y (€/MW); dus C(Y) = Y*P (€)
//1.4) O = Tarieven voor de openbaredienstverplichtingen 
//1.5) T = Toeslagen
//2.	Verschilt NIET per  regio en aansluiting:
//2.1) D = dagen in de maand (dagen)

//= Min(150,8082*X; A*V*D/365 + Y*P*D/365 + 0,1550*D) + (O+T+29,14)*X + 1,751*I + D*7,1316

// loop over scenarios
SET vScenarios = 7;

FOR vS = 1 TO $(vScenarios)
	
	LET vConcat = If(NoOfRows('Costs') > 0, 'CONCATENATE (Costs)', 'Costs:');
	
	$(vConcat)
	LOAD 
		*
//		, RangeMin(150.8082*X, 1993.6709*Y + 2690.0459) + 29.1803*X + 164.2146 as costs_other_scen$(vS)
		, RangeMin(150.8082*X, A*V*D/365 + Y*P*D/365 + 0.1550*D) + (O+T+29.14)*X + 1.751*I + D*7.1316 as costs_other_scen$(vS)
	;
	LOAD 
		my_key
		, Sum(If(power_scen$(vS)_kw > 0, power_scen$(vS)_kw))/4/1000 as X
		, Max(If(power_scen$(vS)_kw > 0, power_scen$(vS)_kw))/1000 as Y
		, Max($(vAansluiting)) / 1000 as A
		, Sum(If(power_scen$(vS)_kw < 0, - power_scen$(vS)_kw))/4/1000 as I
		// Coëfficienten Zenne-Dijle 2026
		, 0.5055198 as E
		, 40.6844988 * 1000 as V
		, 59.85696 * 1000 as P
		, 0.0039196 * 1000 as O
		, 0.0003058 * 1000 as T
		, Max(Floor(datequarterhour)) - Min(Floor(datequarterhour)) + 1 as D
	RESIDENT QhData
	GROUP BY my_key; 
NEXT
///$tab Selection

Temp_QhData: 
LOAD 
	high_power_seq,
	high_power_seq as sel_high_power_seq	
RESIDENT QhData;

CONCATENATE (Temp_QhData)
LOAD 
	high_power_seq + 1 as high_power_seq,
	high_power_seq as sel_high_power_seq	
RESIDENT QhData;

CONCATENATE (Temp_QhData)
LOAD 
	high_power_seq -1 as high_power_seq,
	high_power_seq as sel_high_power_seq	
RESIDENT QhData;

FOR vS = 1 TO $(vScenarios)
	
	Temp_QhData_Scen$(vS): 
	LOAD 
		high_power_scen$(vS)_seq,
		high_power_scen$(vS)_seq as sel_high_power_scen$(vS)_seq	
	RESIDENT QhData;
	
	CONCATENATE (Temp_QhData_Scen$(vS))
	LOAD 
		high_power_scen$(vS)_seq + 1 as high_power_scen$(vS)_seq,
		high_power_scen$(vS)_seq as sel_high_power_scen$(vS)_seq	
	RESIDENT QhData;
	
	CONCATENATE (Temp_QhData_Scen$(vS))
	LOAD 
		high_power_scen$(vS)_seq -1 as high_power_scen$(vS)_seq,
		high_power_scen$(vS)_seq as sel_high_power_scen$(vS)_seq	
	RESIDENT QhData;
	
NEXT
///$tab Exit 
exit script;
