// 2.24GWh Arendonk_Timeseries_51.297_5.105_SA3_2307kWp_CIS_14_38deg_0deg_2020_2023; 
// 2.23GWh Arendonk_Timeseries_51.297_5.105_SA3_2307kWp_crystSi_14_38deg_0deg_2020_2023; 
// 3.2GWh seems too high ==> Arendonk_Timeseries_51.297_5.105_SA3_2307kWp_crystSi_14_38deg_-5deg_2020_2023;

TempPV:
LOAD 
	TimeStamp(AddYears(TimeStamp#(time,'YYYYMMDD:hhmm'), 2)) as time, //20231231:2310, 
     P, 
     [G(i)], 
     H_sun, 
     T2m, 
     WS10m, 
     Int
     , RecNo() as rec
FROM
[$(vFolder)$(vFileName).csv]
(txt, codepage is 1252, embedded labels, delimiter is ',', msq, header is 10 lines, no eof)
WHERE NOT IsNull(TimeStamp(TimeStamp#(time,'YYYYMMDD:hhmm')));


PV:
LOAD 
	*
	, pv_kw_noisy as pv_power_kw
//	, pv_kw_noisy as power_kw
;
LOAD 
	'key:' & TimeStamp(TimeStamp#(TimeStamp(time, 'YYYYMMDD:hh'), 'YYYYMMDD:hh') + (IterNo()-1) * Time#('15:00','mm:ss')) as datequarterhour_key
	, TimeStamp(TimeStamp#(TimeStamp(time, 'YYYYMMDD:hh'), 'YYYYMMDD:hh') + (IterNo()-1) * Time#('15:00','mm:ss')) as datequarterhour
	, 1 * P/1000 as pv_kw_noisy
	, *
RESIDENT TempPV
WHILE IterNo() <=4; 
DROP TABLE TempPV;


