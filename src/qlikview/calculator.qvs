// 2.08GWh Timeseries_51.297_5.105_SA3_2307kWp_crystSi_20_38deg_-5deg_2020_2023;
// 1.2GWh Timeseries_51.297_5.105_SA3_2307kWp_crystSi_50_38deg_-5deg_2020_2023;
